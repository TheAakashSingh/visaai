# =============================
# VisaAI Pro — Environment Config
# =============================

# --- App ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/visaai
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your_refresh_token_secret

# --- OpenAI ---
OPENAI_API_KEY=sk-...your_openai_key
OPENAI_MODEL=gpt-4-turbo-preview

# --- WhatsApp (Meta Business API) ---
WHATSAPP_TOKEN=your_meta_access_token
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id

# --- Twilio (Voice Bot) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# --- ElevenLabs (TTS Voice - optional) ---
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=voice_id_for_priya

# --- Google Vision (OCR) ---
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# --- CRM: Zoho ---
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token

# --- CRM: Salesforce ---
SF_INSTANCE_URL=https://login.salesforce.com
SF_CLIENT_ID=your_sf_consumer_key
SF_CLIENT_SECRET=your_sf_consumer_secret
SF_USERNAME=your_sf_username
SF_PASSWORD=your_sf_password
SF_SECURITY_TOKEN=your_sf_security_token

# --- CRM: HubSpot ---
HUBSPOT_API_KEY=your_hubspot_private_app_token

# --- CRM: Custom Webhook ---
CUSTOM_CRM_WEBHOOK_URL=https://your-crm.com/api/leads/webhook
CUSTOM_CRM_WEBHOOK_SECRET=your_webhook_signing_secret

# --- Default CRM Provider (zoho | salesforce | hubspot | custom | none) ---
DEFAULT_CRM_PROVIDER=zoho

# --- AWS S3 (Document Storage) ---
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=ap-south-1
AWS_S3_BUCKET=visaai-documents

# --- Email ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_SECRET=internal_service_secret
